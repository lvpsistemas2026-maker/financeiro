# ============================================================
# SISTEMA FINANCEIRO LVP — Variáveis de Ambiente
# ============================================================
#
# COMO CONFIGURAR:
# 1. Copie este arquivo: cp .env.example .env.local
# 2. Abra o .env.local e substitua os valores pelos reais
# 3. Reinicie o servidor: npm run dev
#
# ONDE OBTER AS CREDENCIAIS DO SUPABASE:
# → Acesse https://supabase.com e faça login
# → Selecione seu projeto
# → Vá em Settings → API
# → Copie os valores conforme indicado abaixo
# ============================================================

# URL do projeto Supabase
# Exemplo: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave pública anônima (anon public) — pode ser exposta no frontend
# Encontre em: Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SUA-CHAVE-ANON

# Chave de serviço (service_role) — NUNCA exponha no frontend!
# Encontre em: Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SUA-CHAVE-SERVICE-ROLE

# URL da aplicação (use a URL da Vercel em produção)
NEXT_PUBLIC_APP_URL=http://localhost:3000
